# Python environment (regenerate with pip; see STRIX_HALO.md)
.venv

# HuggingFace dataset/model cache (re-downloaded on demand)
.hf_cache

# Pre-chunked shard caches (rebuild with data_prep.py)
chunk_cache/
chunk_cache_shakedown/
chunk_cache_shakedown.STALE-pre-0711-chunker-DO-NOT-TRAIN/
wiki_cache/

# Model checkpoints / shards -- large, regenerable by training.
# runs/ keeps its metrics.json + *.png plots tracked; only the .pt is ignored.
*.pt

# Conference submission material (BayLearn abstract, poster, slides) -- kept
# on disk, out of the repo. The generators (poster.py, tile.py, poster_figs.py,
# build_deck.py) stay tracked; their output does not.
baylearn_abstract.tex
baylearn_abstract.pdf
neurips_2023.sty
HLRA_Poster.*
HLRA_Poster_PrintTiles.*
HLRA_Poster_reference.png
Hierarchical_Latent_Reasoning_Architecture.pptx
poster_figs/
poster_data/

# LaTeX build cruft
*.aux
*.log
*.out
*.synctex.gz

# OS / editor cruft
.DS_Store

# Research PDFs (kept on disk, not in the repo)
# *.pdf
